<?xml version="1.0" encoding="utf-8"?>
<!--
  BabyNote 홈 위젯 — 4×2 (가로4 × 세로2). 4개 타일 각각:
    이모지 / 라벨 / 시간 / 요약
  Flutter 측에서 SharedPreferences로 widget_{type}_time, _summary 키 채움.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg"
    android:padding="6dp">

    <!-- 수유 -->
    <LinearLayout
        android:id="@+id/widget_btn_feeding"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍼"
            android:textSize="22sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_feeding"
            android:textSize="11sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="2dp" />
        <TextView
            android:id="@+id/widget_feeding_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="2"
            android:text="—"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FE7D81"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 수면 -->
    <LinearLayout
        android:id="@+id/widget_btn_sleep"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💤"
            android:textSize="22sp" />
        <TextView
            android:id="@+id/widget_sleep_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_sleep"
            android:textSize="11sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="2dp" />
        <TextView
            android:id="@+id/widget_sleep_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="2"
            android:text="—"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FE7D81"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 기저귀 -->
    <LinearLayout
        android:id="@+id/widget_btn_diaper"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💩"
            android:textSize="22sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_diaper"
            android:textSize="11sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="2dp" />
        <TextView
            android:id="@+id/widget_diaper_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="2"
            android:text="—"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FE7D81"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 성장 -->
    <LinearLayout
        android:id="@+id/widget_btn_growth"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackground">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📏"
            android:textSize="22sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_growth"
            android:textSize="11sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="2dp" />
        <TextView
            android:id="@+id/widget_growth_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="2"
            android:text="—"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FE7D81"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
